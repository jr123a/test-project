4. New category-only update method

public String updateCustomerCategoryOnly() {
    try {
        if (selectedApplicationId == null) {
            addErrorMessage("No application selected.");
            return null;
        }
        if (customerCategoryId == null) {
            addErrorMessage("Customer Category is required.");
            return null;
        }
        sponsorApplicationService.updateCustomerCategoryOnly(
            selectedApplicationId,
            customerCategoryId,
            getLoggedInUser()
        );
        addInfoMessage("Customer Category updated successfully.");
        resetApplicationForm();
        reloadApplicationList();
    } catch (Exception e) {
        addErrorMessage("Unable to update customer category.");
    }
    return null;
}

5. Cancel should reset the mode

public String cancelApplicationEdit() {
    resetApplicationForm();
    return null;
}
private void resetApplicationForm() {
    this.selectedApplication = null;
    this.selectedApplicationId = null;
    this.applicationName = null;
    this.customerCategoryId = null;
    this.customerCategoryOnlyEditMode = false;
    this.showUpdateButton = false;
    this.showCancelButton = false;
    this.showCreateButton = true;
}

