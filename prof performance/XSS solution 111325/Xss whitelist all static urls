private boolean isFrameworkOrStaticResourceRequest(HttpServletRequest hsr) {
    String uri = hsr.getRequestURI();
    String servletPath = hsr.getServletPath();

    if (uri == null) {
        uri = "";
    }
    if (servletPath == null) {
        servletPath = "";
    }

    String path = uri.toLowerCase();

    // JSF / RichFaces / A4J / framework resource paths
    if (path.contains("javax.faces.resource")
            || path.contains("/rfres/")
            || path.contains("/cfres/")
            || path.contains("/a4j/")
            || path.contains("/ips/js/")
            || path.contains("/ips/css/")) {
        return true;
    }

    // Resource names seen in your screenshots / console
    if (path.contains("jsf.js.xhtml")
            || path.contains("status.js.xhtml")
            || path.contains("popuppanel.css.xhtml")
            || path.contains("popuppanel.js.xhtml")
            || path.contains("popuppanelborders.js.xhtml")
            || path.contains("popuppanelsizer.js.xhtml")
            || path.contains("buttonbackgroundimage.png.xhtml")
            || path.contains("buttonhoverbackgroundimage.png.xhtml")
            || path.contains("ipsstyles_otp.css")
            || path.contains("ipscommon.js")
            || path.contains("ips_gtm.js")
            || path.contains("getproperties")) {
        return true;
    }

    // Generic static resource extensions
    return path.endsWith(".js")
            || path.endsWith(".css")
            || path.endsWith(".png")
            || path.endsWith(".gif")
            || path.endsWith(".jpg")
            || path.endsWith(".jpeg")
            || path.endsWith(".svg")
            || path.endsWith(".ico")
            || path.endsWith(".woff")
            || path.endsWith(".woff2")
            || path.endsWith(".ttf")
            || path.endsWith(".map");
}


