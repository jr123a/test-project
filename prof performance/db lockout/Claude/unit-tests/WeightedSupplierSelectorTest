    // =========================================================================
    // SECTION 9 — Thread safety (light concurrency smoke test)
    // =========================================================================

    @Nested
    @DisplayName("Thread safety — concurrent access")
    class ThreadSafetyTests {

        @Test
        @DisplayName("select_shouldNotThrow_whenCalledConcurrentlyFromMultipleThreads")
        void select_shouldNotThrow_whenCalledConcurrentlyFromMultipleThreads()
                throws InterruptedException {
            RpOtpAttemptConfig equifax = config(EQUIFAX_ID,    "Equifax",    60);
            RpOtpAttemptConfig lexis   = config(LEXISNEXIS_ID, "LexisNexis", 40);
            List<RpOtpAttemptConfig> list = Arrays.asList(equifax, lexis);

            int threadCount = 20;
            Thread[] threads = new Thread[threadCount];
            Throwable[] errors = new Throwable[threadCount];

            for (int i = 0; i < threadCount; i++) {
                final int idx = i;
                threads[i] = new Thread(() -> {
                    try {
                        for (int j = 0; j < 1_000; j++) {
                            RpOtpAttemptConfig result = selector.select(list);
                            assertNotNull(result);
                        }
                    } catch (Throwable t) {
                        errors[idx] = t;
                    }
                });
            }

            for (Thread t : threads) t.start();
            for (Thread t : threads) t.join(5_000);

            for (int i = 0; i < threadCount; i++) {
                assertNull(errors[i],
                        "Thread " + i + " threw: " + (errors[i] != null ? errors[i].getMessage() : ""));
            }
        }
    }

    // =========================================================================
    // Helpers
    // =========================================================================

    /** Run {@code selector.select()} {@code iterations} times, return count per supplierId. */
    private Map<Long, Integer> runMany(List<RpOtpAttemptConfig> list, int iterations) {
        Map<Long, Integer> counts = new HashMap<>();
        for (int i = 0; i < iterations; i++) {
            RpOtpAttemptConfig result = selector.select(list);
            assertNotNull(result, "selector.select() must never return null for a non-empty valid list");
            long id = result.getRefOtpSupplier().getOtpSupplierId();
            counts.merge(id, 1, Integer::sum);
        }
        return counts;
    }

    private void assertWithinTolerance(Map<Long, Integer> counts, long supplierId,
                                       double expectedPct, String supplierName) {
        int count = counts.getOrDefault(supplierId, 0);
        double actualPct = count * 100.0 / STAT_ITERATIONS;
        assertTrue(
                actualPct >= expectedPct - TOLERANCE_PCT && actualPct <= expectedPct + TOLERANCE_PCT,
                String.format("%s expected ~%.0f%% ± %.0f%%, but was %.2f%%",
                        supplierName, expectedPct, TOLERANCE_PCT, actualPct));
    }

    /**
     * Creates a minimal {@link RpOtpAttemptConfig} test fixture.
     * The {@code attempts} column is set to 0 by default.
     */
    static RpOtpAttemptConfig config(long supplierId, String supplierName, int totalAttempts) {
        return config(supplierId, supplierName, totalAttempts, 0);
    }

    /**
     * Creates a minimal {@link RpOtpAttemptConfig} with an explicit {@code attempts} value.
     * Used in tests that verify the attempts column is completely ignored.
     */
    static RpOtpAttemptConfig config(long supplierId, String supplierName,
                                     int totalAttempts, int attempts) {
        RefOtpSupplier supplier = new RefOtpSupplier();
        supplier.setOtpSupplierId(supplierId);
        supplier.setOtpSupplierName(supplierName);

        RpOtpAttemptConfig cfg = new RpOtpAttemptConfig();
        cfg.setRefOtpSupplier(supplier);
        cfg.setTotalAttempts(totalAttempts);
        cfg.setAttempts(attempts);  // should have zero effect on selection after refactor
        return cfg;
    }
