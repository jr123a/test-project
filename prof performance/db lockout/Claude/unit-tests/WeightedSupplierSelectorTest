    // =========================================================================
    // SECTION 4 — ATTEMPTS column is irrelevant to selection
    // =========================================================================

    @Nested
    @DisplayName("ATTEMPTS column is irrelevant — only TOTAL_ATTEMPTS drives selection")
    class AttemptsColumnIgnoredTests {

        @Test
        @DisplayName("select_shouldSelectEquifax_evenWhenEquifaxHasHighAttempts")
        void select_shouldSelectEquifax_evenWhenEquifaxHasHighAttempts() {
            // Old code: attempts >= totalAttempts would skip this supplier.
            // New code: attempts column is completely ignored.
            RpOtpAttemptConfig equifaxAtLimit = config(EQUIFAX_ID, "Equifax", 60, /*attempts=*/60);
            RpOtpAttemptConfig lexisBelowLimit = config(LEXISNEXIS_ID, "LexisNexis", 40, /*attempts=*/5);

            // With old logic, Equifax would never be selected (60 >= 60).
            // With new logic, Equifax must be selected ~60% of the time.
            int equifaxCount = 0;
            for (int i = 0; i < STAT_ITERATIONS; i++) {
                long id = selector.select(Arrays.asList(equifaxAtLimit, lexisBelowLimit))
                        .getRefOtpSupplier().getOtpSupplierId();
                if (id == EQUIFAX_ID) equifaxCount++;
            }
            double pct = equifaxCount * 100.0 / STAT_ITERATIONS;
            assertTrue(pct >= 60.0 - TOLERANCE_PCT && pct <= 60.0 + TOLERANCE_PCT,
                    "Equifax should be selected ~60% of the time regardless of attempts column; was " + pct + "%");
        }

        @Test
        @DisplayName("select_shouldHonorWeights_evenWhenAllSuppliersHaveMaxAttempts999")
        void select_shouldHonorWeights_evenWhenAllSuppliersHaveMaxAttempts999() {
            // attempts=999 would have caused the old counter-based logic to reset every time
            RpOtpAttemptConfig equifax  = config(EQUIFAX_ID,    "Equifax",    60, 999);
            RpOtpAttemptConfig lexis    = config(LEXISNEXIS_ID, "LexisNexis", 40, 999);

            int equifaxCount = 0;
            for (int i = 0; i < STAT_ITERATIONS; i++) {
                long id = selector.select(Arrays.asList(equifax, lexis))
                        .getRefOtpSupplier().getOtpSupplierId();
                if (id == EQUIFAX_ID) equifaxCount++;
            }
            double pct = equifaxCount * 100.0 / STAT_ITERATIONS;
            assertTrue(pct >= 60.0 - TOLERANCE_PCT && pct <= 60.0 + TOLERANCE_PCT,
                    "Equifax should be ~60% even at attempts=999; was " + pct + "%");
        }
    }

    // =========================================================================
    // SECTION 5 — Statistical distribution tests (60/40 split)
    // =========================================================================

    @Nested
    @DisplayName("60/40 split — statistical distribution")
    class SixtyFortySplitTests {

        @Test
        @DisplayName("select_shouldApproximatelyHonor60_40Split_overLargeNumberOfCalls")
        void select_shouldApproximatelyHonor60_40Split_overLargeNumberOfCalls() {
            RpOtpAttemptConfig equifax = config(EQUIFAX_ID,    "Equifax",    60);
            RpOtpAttemptConfig lexis   = config(LEXISNEXIS_ID, "LexisNexis", 40);

            Map<Long, Integer> counts = runMany(Arrays.asList(equifax, lexis), STAT_ITERATIONS);

            assertWithinTolerance(counts, EQUIFAX_ID,    60.0, "Equifax");
            assertWithinTolerance(counts, LEXISNEXIS_ID, 40.0, "LexisNexis");
        }

        @Test
        @DisplayName("select_shouldReturn60PercentEquifax_and40PercentLexisNexis_reversed")
        void select_shouldReturn60PercentEquifax_and40PercentLexisNexis_reversed() {
            // Same weights, reversed order in list — result must be the same
            RpOtpAttemptConfig lexis   = config(LEXISNEXIS_ID, "LexisNexis", 40);
            RpOtpAttemptConfig equifax = config(EQUIFAX_ID,    "Equifax",    60);

            Map<Long, Integer> counts = runMany(Arrays.asList(lexis, equifax), STAT_ITERATIONS);

            assertWithinTolerance(counts, EQUIFAX_ID,    60.0, "Equifax");
            assertWithinTolerance(counts, LEXISNEXIS_ID, 40.0, "LexisNexis");
        }
    }

