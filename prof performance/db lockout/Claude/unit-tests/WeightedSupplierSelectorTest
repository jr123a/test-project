import com.ips.entity.RefOtpSupplier;
import com.ips.entity.RpOtpAttemptConfig;

/**
 * JUnit 5 unit tests for {@link WeightedSupplierSelector}.
 *
 * <p>No Spring context, no WebSphere, no Oracle, no Mockito needed.
 * {@link WeightedSupplierSelector} is pure Java; every test constructs
 * objects directly and calls {@code select()} synchronously.
 *
 * <p>Supplier IDs used throughout match the constants declared in
 * {@link RefOtpSupplier}:
 * <ul>
 *   <li>4L = LexisNexis RDP OTP (LEXISNEXIS_RDP_OTP_SUPPLIER_ID)</li>
 *   <li>5L = Equifax IDFS OTP   (EQUIFAX_IDFS_OTP_SUPPLIER_ID)</li>
 *   <li>6L = Experian CrossCore  (EXPERIAN_CROSSCORE_SUPPLIER_ID)</li>
 *   <li>7L = Equifax DIT SMFA   (EQUIFAX_DIT_SMFA_SUPPLIER_ID)</li>
 * </ul>
 *
 * <p>Statistical tolerance is ±3% on the expected percentage.
 * 100 000 iterations give a standard deviation of ~0.15%, so ±3% is
 * more than 20 standard deviations — effectively never flaky.
 */
@DisplayName("WeightedSupplierSelector")
class WeightedSupplierSelectorTest {

    // Supplier IDs that match the production RefOtpSupplier constants
    private static final long LEXISNEXIS_ID = 4L;   // LEXISNEXIS_RDP_OTP_SUPPLIER_ID
    private static final long EQUIFAX_ID    = 5L;   // EQUIFAX_IDFS_OTP_SUPPLIER_ID
    private static final long EXPERIAN_ID   = 6L;   // EXPERIAN_CROSSCORE_SUPPLIER_ID
    private static final long SMFA_ID       = 7L;   // EQUIFAX_DIT_SMFA_SUPPLIER_ID

    private static final int  STAT_ITERATIONS = 100_000;
    private static final double TOLERANCE_PCT = 3.0;   // ±3 percentage points

    private WeightedSupplierSelector selector;

    @BeforeEach
    void setUp() {
        selector = new WeightedSupplierSelector();
    }

    // =========================================================================
    // SECTION 1 — Null / empty / degenerate inputs
    // =========================================================================

    @Nested
    @DisplayName("Null / empty / degenerate inputs")
    class NullAndEmptyInputTests {

        @Test
        @DisplayName("select_shouldReturnNull_whenListIsNull")
        void select_shouldReturnNull_whenListIsNull() {
            assertNull(selector.select(null));
        }

        @Test
        @DisplayName("select_shouldReturnNull_whenListIsEmpty")
        void select_shouldReturnNull_whenListIsEmpty() {
            assertNull(selector.select(Collections.emptyList()));
        }

        @Test
        @DisplayName("select_shouldReturnNull_whenListContainsOnlyNullElements")
        void select_shouldReturnNull_whenListContainsOnlyNullElements() {
            List<RpOtpAttemptConfig> configs = Arrays.asList(null, null);
            assertNull(selector.select(configs));
        }

        @Test
        @DisplayName("select_shouldReturnNull_whenAllSuppliersHaveTotalAttemptsOfZero")
        void select_shouldReturnNull_whenAllSuppliersHaveTotalAttemptsOfZero() {
            List<RpOtpAttemptConfig> configs = Arrays.asList(
                    config(LEXISNEXIS_ID, "LexisNexis", 0),
                    config(EQUIFAX_ID,    "Equifax",    0)
            );
            assertNull(selector.select(configs));
        }
    }

    // =========================================================================
    // SECTION 2 — Zero-percent / disabled suppliers are never selected
    // =========================================================================

    @Nested
    @DisplayName("Zero-totalAttempts suppliers are ignored")
    class ZeroWeightSupplierTests {

        @Test
        @DisplayName("select_shouldIgnoreZeroPercentSupplier_whenOneActiveSupplierExists")
        void select_shouldIgnoreZeroPercentSupplier_whenOneActiveSupplierExists() {
            RpOtpAttemptConfig zero    = config(LEXISNEXIS_ID, "LexisNexis", 0);
            RpOtpAttemptConfig hundred = config(EQUIFAX_ID,    "Equifax",  100);

            // Run many times — zero-weight supplier must never appear
            for (int i = 0; i < 1_000; i++) {
                RpOtpAttemptConfig result = selector.select(Arrays.asList(zero, hundred));
                assertNotNull(result, "Must return a supplier");
                assertEquals(EQUIFAX_ID, result.getRefOtpSupplier().getOtpSupplierId(),
                        "Zero-percent LexisNexis must never be selected");
            }
        }

        @Test
        @DisplayName("select_shouldIgnoreAllZeroPercentSuppliers_andSelectOnlyActive")
        void select_shouldIgnoreAllZeroPercentSuppliers_andSelectOnlyActive() {
            RpOtpAttemptConfig disabled1 = config(LEXISNEXIS_ID, "LexisNexis",  0);
            RpOtpAttemptConfig active     = config(EQUIFAX_ID,    "Equifax",    60);
            RpOtpAttemptConfig disabled2  = config(EXPERIAN_ID,   "Experian",    0);

            for (int i = 0; i < 1_000; i++) {
                RpOtpAttemptConfig result = selector.select(
                        Arrays.asList(disabled1, active, disabled2));
                assertNotNull(result);
                assertEquals(EQUIFAX_ID, result.getRefOtpSupplier().getOtpSupplierId());
            }
        }

        @Test
        @DisplayName("select_shouldNeverSelectZeroWeightSupplier_inHighVolumeRun")
        void select_shouldNeverSelectZeroWeightSupplier_inHighVolumeRun() {
            RpOtpAttemptConfig zero    = config(LEXISNEXIS_ID, "LexisNexis",  0);
            RpOtpAttemptConfig equifax = config(EQUIFAX_ID,    "Equifax",    50);
            RpOtpAttemptConfig experian = config(EXPERIAN_ID,  "Experian",   50);

            List<RpOtpAttemptConfig> list = Arrays.asList(zero, equifax, experian);

            for (int i = 0; i < STAT_ITERATIONS; i++) {
                RpOtpAttemptConfig result = selector.select(list);
                assertNotNull(result);
                assertNotEquals(LEXISNEXIS_ID, result.getRefOtpSupplier().getOtpSupplierId(),
                        "LexisNexis (totalAttempts=0) was selected at iteration " + i);
            }
        }
    }

