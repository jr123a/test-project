    @Nested
    @DisplayName("isSwitchingConfigured() — 100% boundary")
    class SwitchingConfiguredBoundaryTests {

        @Test
        @DisplayName("determineVerificationMethod_shouldNotCallCallingOtp_whenExactly100PercentOnOneSupplier")
        void determineVerificationMethod_shouldNotCallCallingOtp_whenExactly100PercentOnOneSupplier()
                throws Exception {
            PersonVo pv = personVo();
            RpOtpAttemptConfig efFull = otpCfg(EQUIFAX_ID, "Equifax", 100);
            RpOtpAttemptConfig lnZero = otpCfg(LEXISNEXIS_ID, "LexisNexis", 0);

            when(otpAttemptConfigService.getByProofingLevel(anyLong(), anyLong()))
                    .thenReturn(List.of(efFull, lnZero));
            when(otpAttemptConfigService.getByProofingLevelSorted(anyList(), anyLong(), anyLong()))
                    .thenReturn(List.of(efFull));

            service.determineVerificationMethod(pv, loaLevel, sponsor);

            verify(otpAttemptConfigService, never()).callingOTP(any());
        }
