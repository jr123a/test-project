package com.ips.proofing;

import java.util.concurrent.ConcurrentHashMap;
import java.util.concurrent.atomic.AtomicInteger;

import org.springframework.stereotype.Component;

/**
 * In-memory tracker for supplier attempt counts used in split-percentage routing.
 *
 * Replaces the DB UPDATE on rp_kba_attempts / rp_inf_pv_attempts for the
 * hot-path supplier selection decision, eliminating Oracle row-lock contention
 * under high CoA transaction volume.
 *
 * The configured percentages (totalAttempts) are still read from the DB ‚Äî
 * only the rolling attempt counter is kept in memory.
 *
 * Key format: "<sponsorId>:<supplierId>"
 * Threadsafe: AtomicInteger inside ConcurrentHashMap ‚Äî no synchronized blocks needed.
 */
@Component
public class SupplierAttemptTracker {

    // Key: "sponsorId:supplierId"  Value: running attempt count
    private final ConcurrentHashMap<String, AtomicInteger> attemptMap = new ConcurrentHashMap<>();

    private String key(long sponsorId, long supplierId) {
        return sponsorId + ":" + supplierId;
    }

    /**
     * Atomically increments and returns the new attempt count for this supplier.
     */
    public int incrementAndGet(long sponsorId, long supplierId) {
        return attemptMap
            .computeIfAbsent(key(sponsorId, supplierId), k -> new AtomicInteger(0))
            .incrementAndGet();
    }

    /**
     * Returns current count without incrementing.
     */
    public int get(long sponsorId, long supplierId) {
        AtomicInteger counter = attemptMap.get(key(sponsorId, supplierId));
        return counter == null ? 0 : counter.get();
    }

    /**
     * Resets both suppliers for a sponsor back to zero (called when cycle completes).
     */
    public void reset(long sponsorId, long supplierId) {
        AtomicInteger counter = attemptMap.get(key(sponsorId, supplierId));
        if (counter != null) {
            counter.set(0);
        }
    }

    /**
     * Resets all suppliers for a given sponsor (full cycle reset).
     */
    public void resetAll(long sponsorId, Iterable<Long> supplierIds) {
        for (Long supplierId : supplierIds) {
            reset(sponsorId, supplierId);
        }
    }
}


