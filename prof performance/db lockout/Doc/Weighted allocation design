11. Proposed Pseudocode

private RpOtpAttemptConfig selectByWeightedRandom(List<RpOtpAttemptConfig> supplierConfigs) {
    List<RpOtpAttemptConfig> candidates = new ArrayList<>();
    for (RpOtpAttemptConfig config : supplierConfigs) {
        if (config != null && config.getTotalAttempts() > 0) {
            candidates.add(config);
        }
    }
    if (candidates.isEmpty()) {
        return null;
    }
    if (candidates.size() == 1) {
        return candidates.get(0);
    }
    int totalWeight = 0;
    for (RpOtpAttemptConfig candidate : candidates) {
        totalWeight += candidate.getTotalAttempts();
    }
    int random = ThreadLocalRandom.current().nextInt(totalWeight);
    int cumulative = 0;
    for (RpOtpAttemptConfig candidate : candidates) {
        cumulative += candidate.getTotalAttempts();
        if (random < cumulative) {
            return candidate;
        }
    }
    return candidates.get(candidates.size() - 1);
}

Updated selectSupplier(...) flow:

private RefOtpSupplier selectSupplier(PersonVo personVo, RefLoaLevel level, List<RpOtpAttemptConfig> list) {
    RpOtpAttemptConfig chosen = selectByWeightedRandom(list);
    if (chosen == null) {
        return null;
    }
    return chosen.getRefOtpSupplier();
}

