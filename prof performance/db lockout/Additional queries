This may actually become your best human-readable flow trace.

For one person ID, use this sequence:

SELECT
    p.PERSON_ID,
    p.SPONSOR_ID,
    rs.SPONSOR_NAME,
    p.SPONSOR_USER_ID,
    p.PROOFING_LEVEL_SOUGHT,
    p.PROOFING_LEVEL_ACHIEVED,
    p.CREATE_DATE,
    p.UPDATE_DATE
FROM IPS_OWN.PERSON p
LEFT JOIN IPS_OWN.REF_SPONSOR rs
    ON rs.SPONSOR_ID = p.SPONSOR_ID
WHERE p.PERSON_ID = :PERSON_ID;
SELECT
    pd.PERSON_ID,
    pd.FIRST_NAME,
    pd.MIDDLE_NAME,
    pd.LAST_NAME,
    pd.EMAIL_ADDRESS,
    pd.ADDRESS_LINE_1,
    pd.CITY,
    pd.STATE_PROVINCE,
    pd.POSTAL_CODE,
    pd.PHONE_NUMBER,
    pd.CREATE_DATE
FROM IPS_OWN.PERSON_DATA pd
WHERE pd.PERSON_ID = :PERSON_ID;
SELECT
    pps.PERSON_ID,
    pps.PROOFING_LEVEL_SOUGHT,
    pps.PROOFING_STATUS,
    pps.PROOFING_STATUS_DATETIME,
    pps.CREATE_DATE,
    pps.UPDATE_DATE
FROM IPS_OWN.PERSON_PROOFING_STATUS pps
WHERE pps.PERSON_ID = :PERSON_ID
ORDER BY pps.PROOFING_STATUS_DATETIME DESC;
SELECT
    ap.AUDIT_PERSON_ID,
    ap.PERSON_ID,
    ap.SPONSOR_ID,
    rs.SPONSOR_NAME,
    ap.SPONSOR_USER_ID,
    ap.FULL_PERSON_NAME,
    ap.EMAIL_ADDRESS,
    ap.PROOFING_STATUS,
    ap.PROOFING_STATUS_DATETIME,
    ap.PROOFING_LEVEL,
    ap.CREATE_DATE
FROM IPS_OWN.AUDIT_PERSON ap
LEFT JOIN IPS_OWN.REF_SPONSOR rs
    ON rs.SPONSOR_ID = ap.SPONSOR_ID
WHERE ap.PERSON_ID = :PERSON_ID
ORDER BY ap.PROOFING_STATUS_DATETIME, ap.AUDIT_PERSON_ID;

For finding your recent test user quickly:

SELECT
    p.PERSON_ID,
    p.SPONSOR_ID,
    rs.SPONSOR_NAME,
    p.SPONSOR_USER_ID,
    pd.FIRST_NAME,
    pd.LAST_NAME,
    pd.EMAIL_ADDRESS,
    pd.PHONE_NUMBER,
    p.CREATE_DATE
FROM IPS_OWN.PERSON p
JOIN IPS_OWN.PERSON_DATA pd
    ON pd.PERSON_ID = p.PERSON_ID
LEFT JOIN IPS_OWN.REF_SPONSOR rs
    ON rs.SPONSOR_ID = p.SPONSOR_ID
WHERE LOWER(pd.FIRST_NAME) = LOWER(:FIRST_NAME)
   OR LOWER(pd.EMAIL_ADDRESS) = LOWER(:EMAIL_ADDRESS)
ORDER BY p.CREATE_DATE DESC;

