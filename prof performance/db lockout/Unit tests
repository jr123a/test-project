    @Before
    public void setUp() throws Exception {
        service = new VerificationProviderServiceImpl();
        refLoaLevelService = mock(RefLoaLevelService.class);
        refSponsorService = mock(RefSponsorDataService.class);
        otpAttemptConfigService = mock(OtpAttemptConfigService.class);
        rpInfPvAttemptConfigService = mock(RpInfPvAttemptConfigService.class);
        refSponsorConfigurationService = mock(RefSponsorConfigurationService.class);
        inject(service, "refLoaLevelService", refLoaLevelService);
        inject(service, "refSponsorService", refSponsorService);
        inject(service, "otpAttemptConfigService", otpAttemptConfigService);
        inject(service, "rpInfPvAttemptConfigService", rpInfPvAttemptConfigService);
        inject(service, "refSponsorConfigurationService", refSponsorConfigurationService);
    }
    @Test
    public void determineVerificationMethod_shouldSelectSupplierButNotUpdateAttempts() throws Exception {
        PersonVo personVo = new PersonVo();
        personVo.setProofingLevelSought("1.5");
        personVo.setSponsor("Change of Address");
        personVo.setSponsorId(32L);
        RefLoaLevel level = new RefLoaLevel();
        level.setLoaCode(1L);
        RefSponsor sponsor = new RefSponsor();
        sponsor.setSponsorId(32L);
        sponsor.setSponsorName("Change of Address");
        RpOtpAttemptConfig equifax = config(5L, "Equifax", 60);
        RpOtpAttemptConfig lexis = config(4L, "LexisNexis", 40);
        when(refLoaLevelService.findByLevel(anyString())).thenReturn(level);
        when(refSponsorService.findBySponsorName(anyString())).thenReturn(sponsor);
        when(otpAttemptConfigService.getByProofingLevelSorted(anyList(), eq(1L), eq(32L)))
            .thenReturn(Arrays.asList(equifax, lexis));
        RefOtpSupplier selected = service.determineVerificationMethod(personVo);
        assertNotNull(selected);
        assertTrue(selected.getOtpSupplierId() == 5L || selected.getOtpSupplierId() == 4L);
        verify(otpAttemptConfigService, never()).callingOTP(any(RpOtpAttemptConfig.class));
        verify(otpAttemptConfigService, never()).reset(anyLong(), anyLong());
    }
    @Test
    public void determineVerificationMethod_shouldReturnNull_whenNoSupplierConfigExists() throws Exception {
        PersonVo personVo = new PersonVo();
        personVo.setProofingLevelSought("1.5");
        personVo.setSponsor("Change of Address");
        personVo.setSponsorId(32L);
        RefLoaLevel level = new RefLoaLevel();
        level.setLoaCode(1L);
        RefSponsor sponsor = new RefSponsor();
        sponsor.setSponsorId(32L);
        when(refLoaLevelService.findByLevel(anyString())).thenReturn(level);
        when(refSponsorService.findBySponsorName(anyString())).thenReturn(sponsor);
        when(otpAttemptConfigService.getByProofingLevelSorted(anyList(), eq(1L), eq(32L)))
            .thenReturn(Arrays.<RpOtpAttemptConfig>asList());
        RefOtpSupplier selected = service.determineVerificationMethod(personVo);
        assertNull(selected);
        assertTrue(personVo.isHasError());
        verify(otpAttemptConfigService, never()).callingOTP(any(RpOtpAttemptConfig.class));
        verify(otpAttemptConfigService, never()).reset(anyLong(), anyLong());
    }
    private RpOtpAttemptConfig config(long supplierId, String supplierName, int totalAttempts) {
        RefOtpSupplier supplier = new RefOtpSupplier();
        supplier.setOtpSupplierId(supplierId);
        supplier.setOtpSupplierName(supplierName);
        RpOtpAttemptConfig config = new RpOtpAttemptConfig();
        config.setRefOtpSupplier(supplier);
        config.setTotalAttempts(totalAttempts);
        config.setAttempts(0);
        return config;
    }
    private void inject(Object target, String fieldName, Object value) throws Exception {
        Field field = target.getClass().getDeclaredField(fieldName);
        field.setAccessible(true);
        field.set(target, value);
    }
}

What this test suite proves

It proves:

1. 100% / single active supplier works.
2. 0% suppliers are never selected.
3. 60/40 works statistically.
4. 40/35/25 works statistically.
5. Percentages do not have to hardcode to exactly 100.
6. ATTEMPTS no longer affects selection.
7. callingOTP(...) is not called anymore.
8. reset(...) is not called anymore.
9. JSF beans can keep calling the provider service; the fix is isolated in the provider layer.

For POC, I would show the team the selector test first, then the Mockito test proving no DB update path is called.
